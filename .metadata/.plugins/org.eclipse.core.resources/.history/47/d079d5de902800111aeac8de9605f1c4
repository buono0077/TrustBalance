package Progetto;

import java.util.*;
import java.util.concurrent.locks.ReentrantLock;

// ---------------------- CONTO BANCARIO ----------------------
class ContoBancario {
    private double saldo;
    private final ReentrantLock lock = new ReentrantLock();

    public ContoBancario(double saldoIniziale) {
        this.saldo = saldoIniziale;
    }

    public void preleva(double importo) {
        lock.lock();
        try {
            if (saldo >= importo) {
                saldo -= importo;
            }
        } finally {
            lock.unlock();
        }
    }

    public double getSaldo() {
        lock.lock();
        try {
            return saldo;
        } finally {
            lock.unlock();
        }
    }
}

// ---------------------- ASTA BOT ----------------------
class AstaBOT {
    private double prezzoCorrente;
    private int vincitore = -1;
    private final ReentrantLock lock = new ReentrantLock();

    public AstaBOT() {
        this.prezzoCorrente = 80.0;
    }

    public void faiOfferta(int idUtente, double offerta) {
        lock.lock(); // MUTEX → SEZIONE CRITICA
        try {
            if (offerta > prezzoCorrente) {
                prezzoCorrente = offerta;
                vincitore = idUtente;

                System.out.println("LOG: Utente " + idUtente +
                        " ha fatto offerta: " +
                        String.format("%.2f £", offerta));
            }
        } finally {
            lock.unlock();
        }
    }

    public int getVincitore() {
        return vincitore;
    }

    public double getPrezzoFinale() {
        return prezzoCorrente;
    }
}

// ---------------------- INVESTITORE (THREAD) ----------------------
class Investitore extends Thread {
    private final int id;
    private final ContoBancario conto;
    private final List<AstaBOT> aste;
    private final Random random = new Random();

    public Investitore(int id, ContoBancario conto, List<AstaBOT> aste) {
        this.id = id;
        this.conto = conto;
        this.aste = aste;
    }

    @Override
    public void run() {
        for (AstaBOT asta : aste) {

            // prezzo casuale tra 80 e 100 con decimali
            double offerta = 80 + (20 * random.nextDouble());

            asta.faiOfferta(id, offerta);
        }

        // SPESA MENSILE (richiesta tua)
        int spesa = 1000 + random.nextInt(2001);

        System.out.println("l'utente " + id +
                " ha speso " + spesa +
                " in questo mese");
    }
}