package Progetto;

import java.util.ArrayList;
import java.util.List;
import java.util.Random;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;
import java.util.concurrent.TimeUnit;

//================= MAIN =================
public class TrustBalanceSimulation {

 public static void main(String[] args) throws InterruptedException {

     int NUM_INVESTITORI = 50;
     int NUM_ASTE = 5;

     List<Conto> conti = new ArrayList<>();
     List<Double> saldiIniziali = new ArrayList<>();
     List<AstaBOT> aste = new ArrayList<>();

     Random random = new Random();

     // ===== CREAZIONE CONTI =====
     for (int i = 0; i < NUM_INVESTITORI; i++) {
         double saldo = 5000 + (45000 * random.nextDouble());
         conti.add(new Conto(saldo));
         saldiIniziali.add(saldo);
     }

     // ===== CREAZIONE ASTE =====
     for (int i = 0; i < NUM_ASTE; i++) {
         aste.add(new AstaBOT(80.00));
     }

     // ===== STAMPA SALDI INIZIALI =====
     System.out.println("=== SALDI INIZIALI ===");
     for (int i = 0; i < conti.size(); i++) {
         System.out.println("Investitore " + i + ": " 
             + String.format("%.2f", saldiIniziali.get(i)) + " €");
     }

     // ===== THREAD =====
     ExecutorService executor = Executors.newFixedThreadPool(50);

     for (int i = 0; i < NUM_INVESTITORI; i++) {
         executor.execute(new Investitore(i, conti.get(i), aste));
     }

     executor.shutdown();
     executor.awaitTermination(1, TimeUnit.MINUTES);

     // ===== SALDI FINALI =====
     System.out.println("\n=== SALDI FINALI ===");
     for (int i = 0; i < conti.size(); i++) {
         double saldoFinale = conti.get(i).getSaldo();
         double differenza = saldoFinale - saldiIniziali.get(i);

         System.out.println("Investitore " + i + ": "
                 + String.format("%.2f", saldoFinale) + " €"
                 + " | Differenza: "
                 + String.format("%.2f", differenza) + " €");
     }

     // ===== RISULTATI ASTE =====
     System.out.println("\n=== PREZZI FINALI ASTE ===");
     for (int i = 0; i < aste.size(); i++) {
         System.out.println("Asta " + i + ": "
                 + String.format("%.2f", aste.get(i).getPrezzoCorrente()) + " €");
     }
 }
}